{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "memory: ingest commit",
      "detail": "Ingest the latest commit into memory (runs automatically via git hook)",
      "type": "shell",
      "command": "python3 \"${env:HOME}/.ai-memory-system/scripts/memory_cli.py\" ingest",
      "group": "none",
      "presentation": { "reveal": "silent", "panel": "shared", "close": true },
      "problemMatcher": []
    },
    {
      "label": "memory: sync to repo",
      "detail": "Regenerate CONTEXT.md and decisions.md from latest memory",
      "type": "shell",
      "command": "python3 \"${env:HOME}/.ai-memory-system/scripts/memory_cli.py\" sync",
      "group": "none",
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "memory: query",
      "detail": "Search memory — you will be prompted for search terms",
      "type": "shell",
      "command": "python3 \"${env:HOME}/.ai-memory-system/scripts/memory_cli.py\" query \"${input:queryTerms}\" --format context",
      "group": "none",
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "memory: log note",
      "detail": "Add a manual note to today's daily log",
      "type": "shell",
      "command": "python3 \"${env:HOME}/.ai-memory-system/scripts/memory_cli.py\" log --message \"${input:logNote}\"",
      "group": "none",
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "memory: show context",
      "detail": "Print the current CONTEXT.md block — what Copilot sees",
      "type": "shell",
      "command": "python3 \"${env:HOME}/.ai-memory-system/scripts/memory_cli.py\" context",
      "group": "none",
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "memory: update graph",
      "detail": "Rebuild the knowledge graph from all stored entries",
      "type": "shell",
      "command": "python3 \"${env:HOME}/.ai-memory-system/scripts/memory_cli.py\" graph",
      "group": "none",
      "presentation": { "reveal": "silent", "panel": "shared", "close": true },
      "problemMatcher": []
    },
    {
      "label": "memory: status",
      "detail": "Show all registered projects and entry counts",
      "type": "shell",
      "command": "python3 \"${env:HOME}/.ai-memory-system/scripts/memory_cli.py\" status",
      "group": "none",
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "memory: init project",
      "detail": "Initialise ai-memory for this repo (run once per repo)",
      "type": "shell",
      "command": "python3 \"${env:HOME}/.ai-memory-system/scripts/memory_cli.py\" init --project \"${input:projectSlug}\" --repo \"${workspaceFolder}\"",
      "group": "none",
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "queryTerms",
      "type": "promptString",
      "description": "Search terms  (e.g. 'auth decisions', 'blocker', 'asyncpg')",
      "default": ""
    },
    {
      "id": "logNote",
      "type": "promptString",
      "description": "Note for today's log  (e.g. 'decided to use JWT over sessions')",
      "default": ""
    },
    {
      "id": "projectSlug",
      "type": "promptString",
      "description": "Project slug — short, lowercase, no spaces  (e.g. 'signal', 'my-api')",
      "default": ""
    }
  ]
}
