#!/bin/sh
# ============================================================
# ai-memory — post-commit hook
# ============================================================
# Installation:
#   cp hooks/post-commit .git/hooks/post-commit
#   chmod +x .git/hooks/post-commit
#
# Or run: python3 scripts/memory_cli.py init --project <slug>
# ============================================================
set -e

# Resolve script location relative to repo root
REPO_ROOT="$(git rev-parse --show-toplevel)"
MEMORY_CLI="$REPO_ROOT/scripts/memory_cli.py"

# Fallback to global install if not in repo scripts/
if [ ! -f "$MEMORY_CLI" ]; then
  MEMORY_CLI="$HOME/.ai-memory/scripts/memory_cli.py"
fi

# Project slug — auto-detected from .ai-memory/index.json or repo name
PROJECT=""

# Use py launcher on Windows, fall back to python3 on Unix
PY="$(command -v py 2>/dev/null || command -v python3 2>/dev/null || echo python3)"

# Run silently — failures must never block git
#!/bin/sh
# ai-memory post-commit hook
# Calls ingest, sync, scan (incremental), and feature_close

if [ "$AI_MEMORY_RUNNING" = "1" ]; then
  exit 0
fi
export AI_MEMORY_RUNNING=1

python3 scripts/ingest.py 2>/dev/null || true
python3 scripts/sync.py 2>/dev/null || true
python3 scripts/scan.py --incremental 2>/dev/null || true
python3 scripts/feature_close.py 2>/dev/null || true
